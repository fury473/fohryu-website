{
  "name": "fohryu-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host 0.0.0.0",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "cf:deploy:production": "node ./node_modules/wrangler/bin/wrangler.js deploy",
    "cf:deploy:preview": "node ./node_modules/wrangler/bin/wrangler.js versions upload",
    "deploy:production": "npm run build && npm run cf:deploy:production",
    "deploy:preview": "npm run build && npm run cf:deploy:preview"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wrangler": "^4.24.0"
  }
}
